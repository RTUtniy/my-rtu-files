\text{3) }\overline x=27;~S^2\approx0,0127~~\Rarr~~S=0,1127\\
\text{4) }\gamma=95\%~~\Rarr~~\alpha=5\%\\
\begin{rcases}
\text{izlases apjoms ir mazs}\\
\sigma\text{ nav zināma}\\
X\sim N(\mu,\sigma^2)
\end{rcases}\Rarr\text{Vajag izmantot Stjūdenta sadalījumu}\\
\mu\in\overline x\pm t_{\alpha,v}\frac{S}{\sqrt{n}}\text{ kur }t_{\alpha,v}=\mathtt{T.INV.2T(\alpha,v)}\\
\sigma^2\in\left(\frac{(n-1)S^2}{\chi^2_{{\small\frac\alpha2},v}};\frac{(n-1)S^2}{\chi^2_{1-{\small\frac\alpha2},v}}\right)\\[1em]

% tālāk es ņihuja nesapratu

\uzdevumsVII{7.2. uzdevums}\\
\text{1) }
X\text{ -- riepas nobraukums (tūkst. km)}\\
X\sim N(\mu;~\sigma^2)\\
\begin{rcases}
n>30\\
\sigma\text{ nav zināma}\\
X\sim N(\mu;~\sigma^2)
\end{rcases}\Rarr \text{var izmantot Stjūdenta sadalījumu}\\
\frac{S}{\sqrt n}\approx1,3297\\
v=60-1=59;~~\alpha=0,05\\
t_{0,05;59}\approx2,001\\
\varepsilon=t_{v;n}\*\frac{S}{\sqrt n}\approx2,66\\
\text{Atbilde: Ar varbūtību 95\% var apgalvot, ka riepas nobraukums būs}\\
\text{intervālā 45}\pm2,66\text{ km}\\[.5em]

