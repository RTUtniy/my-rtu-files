\title{Varbūtība}
\subtitle{11.03.2026 | Praktiskā nodarbība | Aija Pola}

\uzdevumsVI{6.4. uzdevums}\\

\text{1. posms: studenti saņem eksāmena rezultātus un veidojas divas grupas.}\\
\text{2. posms: nejauši izvēlēts students}\\
A=\set{\text{"studenta rezultāts nepārsniedz 80 punktus"}}\\
H_1=\set{\text{"1. gr."}};~P(H_1)=\cfrac{12}{30}=0,4\\
H_1=\set{\text{"2. gr."}};~P(H_1)=\cfrac{18}{30}=0,6\\
P(A|H_j)=~?\\
X_1\text{ -- 1. grupas stud. rez., }X_1\sim N(\mu_1;~\sigma_1^2)\text{ kur }\mu_1=70;~\sigma_1=8\\
X_2\text{ -- 2. grupas stud. rez., }X_2\sim N(\mu_2;~\sigma_2^2)\text{ kur }\mu_2=78;~\sigma_2=6\\
P(A|H_1)=P(X_1<80)=\Phi\left(\frac{80-70}8\right)\approx0,8944\\
P(A|H_2)=P(X_2<80)=\Phi\left(\frac{80-78}6\right)\approx0,6293\\
P(A)=P(A|H_1)\*P(H_1) + P(A|H_2)\*P(H_2)\approx0,735\\[3em]


\title{Statistika}
\subtitle{04.03.2026 | Praktiskā nodarbība | Aija Pola}

\uzdevumsVII{7.1. uzdevums}\\
\text{1)}~~~
